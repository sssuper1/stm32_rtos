 160:Core/Src/bsp_stm32.c **** }
 161:Core/Src/bsp_stm32.c **** 
 162:Core/Src/bsp_stm32.c **** static void oled_flush_dirty_pages(void)
 163:Core/Src/bsp_stm32.c **** {
 164:Core/Src/bsp_stm32.c ****   for (uint8_t p = 0u; p < OLED_PAGES; ++p)
 165:Core/Src/bsp_stm32.c ****   {
 166:Core/Src/bsp_stm32.c ****     if ((s_oledDirtyMask & (uint8_t)(1u << p)) != 0u)
 167:Core/Src/bsp_stm32.c ****     {
 168:Core/Src/bsp_stm32.c ****       oled_flush_page(p);
 169:Core/Src/bsp_stm32.c ****     }
 170:Core/Src/bsp_stm32.c ****   }
 171:Core/Src/bsp_stm32.c **** }
