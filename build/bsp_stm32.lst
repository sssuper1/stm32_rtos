 191:Core/Src/bsp_stm32.c **** static void oled_basic_init(void)
 192:Core/Src/bsp_stm32.c **** {
 193:Core/Src/bsp_stm32.c ****   /* SSD1306 常用初始化序列（128x64） */
 194:Core/Src/bsp_stm32.c ****   oled_write_cmd(0xAE); /* Display OFF */
 195:Core/Src/bsp_stm32.c ****   oled_write_cmd(0x20); /* Memory Addressing Mode */
 196:Core/Src/bsp_stm32.c ****   oled_write_cmd(0x00); /* Horizontal Addressing Mode */
 197:Core/Src/bsp_stm32.c ****   oled_write_cmd(0xB0); /* Page Start Address */
 198:Core/Src/bsp_stm32.c ****   oled_write_cmd(0xC8); /* COM Output Scan Direction remapped */
