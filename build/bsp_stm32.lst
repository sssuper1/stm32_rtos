  90:Core/Src/bsp_stm32.c **** static void oled_write_cmd(uint8_t cmd)
  91:Core/Src/bsp_stm32.c **** {
  92:Core/Src/bsp_stm32.c ****   uint8_t tx[2] = {OLED_CTRL_CMD, cmd};
  93:Core/Src/bsp_stm32.c ****   (void)HAL_I2C_Master_Transmit(&hi2c2, OLED_I2C_ADDR, tx, 2U, 20U);
  94:Core/Src/bsp_stm32.c **** }
  95:Core/Src/bsp_stm32.c **** 
  96:Core/Src/bsp_stm32.c **** static void oled_set_cursor(uint8_t page, uint8_t column)
  97:Core/Src/bsp_stm32.c **** {
  98:Core/Src/bsp_stm32.c ****   oled_write_cmd((uint8_t)(0xB0u + (page & 0x07u)));
  99:Core/Src/bsp_stm32.c ****   oled_write_cmd((uint8_t)(0x00u + (column & 0x0Fu)));
 100:Core/Src/bsp_stm32.c ****   oled_write_cmd((uint8_t)(0x10u + ((column >> 4) & 0x0Fu)));
 101:Core/Src/bsp_stm32.c **** }
 102:Core/Src/bsp_stm32.c **** 
 103:Core/Src/bsp_stm32.c **** static void oled_write_data(const uint8_t *data, uint16_t len)
 104:Core/Src/bsp_stm32.c **** {
 105:Core/Src/bsp_stm32.c ****   uint8_t tx[1U + OLED_CHUNK_SIZE];
 106:Core/Src/bsp_stm32.c ****   tx[0] = OLED_CTRL_DATA;
 107:Core/Src/bsp_stm32.c **** 
 108:Core/Src/bsp_stm32.c ****   while (len > 0u)
 109:Core/Src/bsp_stm32.c ****   {
 110:Core/Src/bsp_stm32.c ****     uint16_t chunk = (len > OLED_CHUNK_SIZE) ? OLED_CHUNK_SIZE : len;
 111:Core/Src/bsp_stm32.c ****     memcpy(&tx[1], data, chunk);
 112:Core/Src/bsp_stm32.c ****     (void)HAL_I2C_Master_Transmit(&hi2c2, OLED_I2C_ADDR, tx, (uint16_t)(chunk + 1u), 20U);
 113:Core/Src/bsp_stm32.c **** 
 114:Core/Src/bsp_stm32.c ****     data += chunk;
 115:Core/Src/bsp_stm32.c ****     len = (uint16_t)(len - chunk);
 116:Core/Src/bsp_stm32.c ****   }
 117:Core/Src/bsp_stm32.c **** }
 118:Core/Src/bsp_stm32.c **** 
 119:Core/Src/bsp_stm32.c **** static void oled_flush_page(uint8_t page)
 120:Core/Src/bsp_stm32.c **** {
 121:Core/Src/bsp_stm32.c ****   if (page >= OLED_PAGES)
 122:Core/Src/bsp_stm32.c ****   {
 123:Core/Src/bsp_stm32.c ****     return;
 124:Core/Src/bsp_stm32.c ****   }
 125:Core/Src/bsp_stm32.c **** 
 126:Core/Src/bsp_stm32.c ****   oled_set_cursor(page, 0u);
 127:Core/Src/bsp_stm32.c ****   oled_write_data(s_oledBack[page], OLED_WIDTH);
 128:Core/Src/bsp_stm32.c ****   memcpy(s_oledFront[page], s_oledBack[page], OLED_WIDTH);
 129:Core/Src/bsp_stm32.c ****   s_oledDirtyMask = (uint8_t)(s_oledDirtyMask & (uint8_t)~(1u << page));
 130:Core/Src/bsp_stm32.c **** }
 131:Core/Src/bsp_stm32.c **** 
 132:Core/Src/bsp_stm32.c **** static void oled_clear_page(uint8_t page)
 133:Core/Src/bsp_stm32.c **** {
 134:Core/Src/bsp_stm32.c ****   if (page >= OLED_PAGES)
 135:Core/Src/bsp_stm32.c ****   {
 136:Core/Src/bsp_stm32.c ****     return;
 137:Core/Src/bsp_stm32.c ****   }
 138:Core/Src/bsp_stm32.c ****   memset(s_oledBack[page], 0, OLED_WIDTH);
 139:Core/Src/bsp_stm32.c **** }
 140:Core/Src/bsp_stm32.c **** 
 141:Core/Src/bsp_stm32.c **** static void oled_flush_all(void)
 142:Core/Src/bsp_stm32.c **** {
 143:Core/Src/bsp_stm32.c ****   for (uint8_t p = 0u; p < OLED_PAGES; ++p)
 144:Core/Src/bsp_stm32.c ****   {
 145:Core/Src/bsp_stm32.c ****     oled_flush_page(p);
 146:Core/Src/bsp_stm32.c ****   }
