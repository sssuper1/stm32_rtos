 172:Core/Src/freertos.c **** /**
 173:Core/Src/freertos.c ****   * @brief  Function implementing the HMI_Task thread.
 174:Core/Src/freertos.c ****   * @param  argument: Not used
 175:Core/Src/freertos.c ****   * @retval None
 176:Core/Src/freertos.c ****   */
 177:Core/Src/freertos.c **** /* USER CODE END Header_StartDefaultTask */
 178:Core/Src/freertos.c **** void StartDefaultTask(void *argument)
 179:Core/Src/freertos.c **** {
 180:Core/Src/freertos.c ****   /* USER CODE BEGIN StartDefaultTask */
 181:Core/Src/freertos.c ****   /* Initialize BSP (LED / LCD / Keys / UART helpers) and menu state machine */
 182:Core/Src/freertos.c ****   BSP_Init();
 183:Core/Src/freertos.c ****   BSP_Lcd_Init();
 184:Core/Src/freertos.c ****   BSP_Keys_Init();
 185:Core/Src/freertos.c ****   (void)APP_Menu_Init();
 186:Core/Src/freertos.c **** 
 187:Core/Src/freertos.c ****   /* Infinite loop */
 188:Core/Src/freertos.c ****   for(;;)
 189:Core/Src/freertos.c ****   {
 190:Core/Src/freertos.c ****     int32_t workModeBefore = 0;
 191:Core/Src/freertos.c ****     (void)APP_ParamDict_GetValue(PARAM_ID_WORK_MODE, &workModeBefore);
 192:Core/Src/freertos.c **** 
 193:Core/Src/freertos.c ****     /* 1. Read key input (polling or from buffer) */
 194:Core/Src/freertos.c ****     MenuKey_t key = HMI_ReadKey();
 195:Core/Src/freertos.c **** 
 196:Core/Src/freertos.c ****     /* 2. Drive menu state machine if there is a key event */
 197:Core/Src/freertos.c ****     if (key != MENU_KEY_NONE)
 198:Core/Src/freertos.c ****     {
 199:Core/Src/freertos.c ****       (void)APP_Menu_HandleKey(key);
 200:Core/Src/freertos.c **** 
 201:Core/Src/freertos.c ****       int32_t workModeAfter = workModeBefore;
 202:Core/Src/freertos.c ****       if (APP_ParamDict_GetValue(PARAM_ID_WORK_MODE, &workModeAfter) &&
 203:Core/Src/freertos.c ****           (workModeAfter != workModeBefore) &&
 204:Core/Src/freertos.c ****           (gParamUpdateQueueHandle != NULL))
ARM GAS  /tmp/ccClMZ2p.s 			page 5


 205:Core/Src/freertos.c ****       {
 206:Core/Src/freertos.c ****         ParamUpdateMsg_t txMsg;
 207:Core/Src/freertos.c ****         txMsg.id = PARAM_ID_WORK_MODE;
 208:Core/Src/freertos.c ****         txMsg.value = workModeAfter;
 209:Core/Src/freertos.c ****         (void)osMessageQueuePut(gParamUpdateQueueHandle, &txMsg, 0U, 0U);
 210:Core/Src/freertos.c ****       }
 211:Core/Src/freertos.c ****     }
 212:Core/Src/freertos.c **** 
 213:Core/Src/freertos.c ****     /* 3. Delay to control polling period (e.g. 10ms) */
 214:Core/Src/freertos.c ****     osDelay(10);
 215:Core/Src/freertos.c ****   }
 216:Core/Src/freertos.c ****   /* USER CODE END StartDefaultTask */
 217:Core/Src/freertos.c **** }
 218:Core/Src/freertos.c **** 
 219:Core/Src/freertos.c **** /* USER CODE BEGIN Header_StartTask02 */
 220:Core/Src/freertos.c **** /**
 221:Core/Src/freertos.c **** * @brief Function implementing the UART_Task thread.
 222:Core/Src/freertos.c **** * @param argument: Not used
 223:Core/Src/freertos.c **** * @retval None
 224:Core/Src/freertos.c **** */
 225:Core/Src/freertos.c **** /* USER CODE END Header_StartTask02 */
 226:Core/Src/freertos.c **** void StartTask02(void *argument)
 227:Core/Src/freertos.c **** {
 228:Core/Src/freertos.c ****   /* USER CODE BEGIN StartTask02 */
 229:Core/Src/freertos.c ****   /* UART_Comm_Task: wait for parameter update messages and send via UART (skeleton) */
 230:Core/Src/freertos.c ****   ParamUpdateMsg_t msg;
 231:Core/Src/freertos.c **** 
 232:Core/Src/freertos.c ****   /* Infinite loop */
 233:Core/Src/freertos.c ****   for(;;)
 234:Core/Src/freertos.c ****   {
 235:Core/Src/freertos.c ****     /* Block until there is a new parameter update request from HMI */
 236:Core/Src/freertos.c ****     if (osMessageQueueGet(gParamUpdateQueueHandle, &msg, NULL, osWaitForever) == osOK)
 237:Core/Src/freertos.c ****     {
 238:Core/Src/freertos.c ****       /* Assemble UART frame and transmit according to protocol. */
 239:Core/Src/freertos.c ****       UART_SendParamWrite(&msg);
 240:Core/Src/freertos.c ****     }
 241:Core/Src/freertos.c ****   }
 242:Core/Src/freertos.c ****   /* USER CODE END StartTask02 */
 243:Core/Src/freertos.c **** }
 244:Core/Src/freertos.c **** 
 245:Core/Src/freertos.c **** /* USER CODE BEGIN Header_StartTask03 */
