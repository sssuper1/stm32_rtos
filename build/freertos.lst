 321:Core/Src/freertos.c **** /* USER CODE BEGIN Header_StartTask03 */
 322:Core/Src/freertos.c **** /**
 323:Core/Src/freertos.c **** * @brief Function implementing the Logic_Task thread.
 324:Core/Src/freertos.c **** * @param argument: Not used
 325:Core/Src/freertos.c **** * @retval None
 326:Core/Src/freertos.c **** */
 327:Core/Src/freertos.c **** /* USER CODE END Header_StartTask03 */
 328:Core/Src/freertos.c **** void StartTask03(void *argument)
 329:Core/Src/freertos.c **** {
 330:Core/Src/freertos.c ****   /* USER CODE BEGIN StartTask03 */
 331:Core/Src/freertos.c ****   /* Infinite loop */
 332:Core/Src/freertos.c ****   for(;;)
 333:Core/Src/freertos.c ****   {
 334:Core/Src/freertos.c **** #if UART_DIAG_SELF_TX_ENABLE
 335:Core/Src/freertos.c ****     {
 336:Core/Src/freertos.c ****       static uint32_t lastSelfTxTick = 0u;
 337:Core/Src/freertos.c ****       uint32_t now = osKernelGetTickCount();
 338:Core/Src/freertos.c ****       if ((now - lastSelfTxTick) >= 1000u)
 339:Core/Src/freertos.c ****       {
 340:Core/Src/freertos.c ****         lastSelfTxTick = now;
