 231:Core/Src/freertos.c **** /**
 232:Core/Src/freertos.c ****   * @brief  Function implementing the HMI_Task thread.
 233:Core/Src/freertos.c ****   * @param  argument: Not used
 234:Core/Src/freertos.c ****   * @retval None
 235:Core/Src/freertos.c ****   */
 236:Core/Src/freertos.c **** /* USER CODE END Header_StartDefaultTask */
 237:Core/Src/freertos.c **** void StartDefaultTask(void *argument)
 238:Core/Src/freertos.c **** {
 239:Core/Src/freertos.c ****   /* USER CODE BEGIN StartDefaultTask */
 240:Core/Src/freertos.c ****   /* Initialize BSP (LED / LCD / Keys / UART helpers) and menu state machine */
 241:Core/Src/freertos.c ****   BSP_Init();
 242:Core/Src/freertos.c ****   BSP_Lcd_Init();
 243:Core/Src/freertos.c ****   BSP_Keys_Init();
 244:Core/Src/freertos.c **** 
 245:Core/Src/freertos.c ****   (void)APP_Menu_Init();
 246:Core/Src/freertos.c ****   uint32_t ignoreKeysUntil = osKernelGetTickCount() + 300U;
 247:Core/Src/freertos.c ****   uint32_t lastActionTick = osKernelGetTickCount();
 248:Core/Src/freertos.c **** 
 249:Core/Src/freertos.c ****   /* Infinite loop */
 250:Core/Src/freertos.c ****   for(;;)
 251:Core/Src/freertos.c ****   {
 252:Core/Src/freertos.c ****     /* 兜底解析：确保即使 UART/Logic 任务异常，也能消费 ISR 缓冲字节。 */
 253:Core/Src/freertos.c ****     APP_UartRx_ProcessPending();
 254:Core/Src/freertos.c **** 
 255:Core/Src/freertos.c ****     /* 1. Read key input (polling or from buffer) */
 256:Core/Src/freertos.c ****     MenuKey_t key = HMI_ReadKey();
 257:Core/Src/freertos.c ****     if (osKernelGetTickCount() < ignoreKeysUntil)
 258:Core/Src/freertos.c ****     {
 259:Core/Src/freertos.c ****       key = MENU_KEY_NONE;
 260:Core/Src/freertos.c ****     }
ARM GAS  /tmp/cc86SiJF.s 			page 6


 261:Core/Src/freertos.c **** 
 262:Core/Src/freertos.c ****     /* 2. Drive menu state machine if there is a key event */
 263:Core/Src/freertos.c ****     if (key != MENU_KEY_NONE)
 264:Core/Src/freertos.c ****     {
 265:Core/Src/freertos.c ****       lastActionTick = osKernelGetTickCount();
 266:Core/Src/freertos.c ****       (void)APP_Menu_HandleKey(key);
 267:Core/Src/freertos.c ****     }
 268:Core/Src/freertos.c ****     else
 269:Core/Src/freertos.c ****     {
 270:Core/Src/freertos.c ****       if ((osKernelGetTickCount() - lastActionTick) > 60000U)
 271:Core/Src/freertos.c ****       {
 272:Core/Src/freertos.c ****         const MenuNode_t *curr = APP_Menu_GetCurrent();
 273:Core/Src/freertos.c ****         if ((curr != NULL) && (curr->id != MENU_ID_ROOT))
 274:Core/Src/freertos.c ****         {
 275:Core/Src/freertos.c ****           APP_Menu_ReturnToRoot();
 276:Core/Src/freertos.c ****         }
 277:Core/Src/freertos.c ****         lastActionTick = osKernelGetTickCount();
 278:Core/Src/freertos.c ****       }
 279:Core/Src/freertos.c ****     }
 280:Core/Src/freertos.c **** 
 281:Core/Src/freertos.c ****     /* 3. Delay to control polling period (e.g. 10ms) */
 282:Core/Src/freertos.c ****     osDelay(10);
 283:Core/Src/freertos.c ****   }
 284:Core/Src/freertos.c ****   /* USER CODE END StartDefaultTask */
 285:Core/Src/freertos.c **** }
