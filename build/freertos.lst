 288:Core/Src/freertos.c **** /**
 289:Core/Src/freertos.c **** * @brief Function implementing the UART_Task thread.
 290:Core/Src/freertos.c **** * @param argument: Not used
 291:Core/Src/freertos.c **** * @retval None
 292:Core/Src/freertos.c **** */
 293:Core/Src/freertos.c **** /* USER CODE END Header_StartTask02 */
 294:Core/Src/freertos.c **** void StartTask02(void *argument)
 295:Core/Src/freertos.c **** {
 296:Core/Src/freertos.c ****   /* USER CODE BEGIN StartTask02 */
 297:Core/Src/freertos.c ****   /* UART_Comm_Task: Receive DMA UART data and wait for parameter update messages */
 298:Core/Src/freertos.c ****   ParamUpdateMsg_t msg;
 299:Core/Src/freertos.c **** 
 300:Core/Src/freertos.c ****   /* Initialize UART RX state machine */
 301:Core/Src/freertos.c ****   APP_UartRx_Init();
 302:Core/Src/freertos.c **** 
 303:Core/Src/freertos.c ****   /* Infinite loop */
 304:Core/Src/freertos.c ****   for(;;)
 305:Core/Src/freertos.c ****   {
 306:Core/Src/freertos.c ****     /* 1. Process any pending UART RX bytes mapped from IDLE interrupt DMA */
 307:Core/Src/freertos.c ****     APP_UartRx_ProcessPending();
 308:Core/Src/freertos.c **** 
 309:Core/Src/freertos.c ****     /* 2. Block for a short time to wait for a new parameter update request from HMI,
 310:Core/Src/freertos.c ****      *    timeout 10ms so we can loop back and check RX quickly.
 311:Core/Src/freertos.c ****      */
 312:Core/Src/freertos.c ****     if (osMessageQueueGet(gParamUpdateQueueHandle, &msg, NULL, 10U) == osOK)
 313:Core/Src/freertos.c ****     {
 314:Core/Src/freertos.c ****       /* Assemble UART frame and transmit according to protocol. */
 315:Core/Src/freertos.c ****       (void)UART_SendParamWrite(&msg);
 316:Core/Src/freertos.c ****     }
 317:Core/Src/freertos.c ****   }
ARM GAS  /tmp/cc86SiJF.s 			page 7


 318:Core/Src/freertos.c ****   /* USER CODE END StartTask02 */
 319:Core/Src/freertos.c **** }
