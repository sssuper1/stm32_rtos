 101:Core/Src/freertos.c **** /* Simple helpers for locking/unlocking parameter dictionary */
 102:Core/Src/freertos.c **** static inline void ParamDict_Lock(void)
 103:Core/Src/freertos.c **** {
 104:Core/Src/freertos.c ****   (void)osMutexAcquire(gParamMutexHandle, osWaitForever);
 105:Core/Src/freertos.c **** }
 106:Core/Src/freertos.c **** 
 107:Core/Src/freertos.c **** static inline void ParamDict_Unlock(void)
 108:Core/Src/freertos.c **** {
 109:Core/Src/freertos.c ****   (void)osMutexRelease(gParamMutexHandle);
 110:Core/Src/freertos.c **** }
 111:Core/Src/freertos.c **** 
 112:Core/Src/freertos.c **** bool APP_ParamUpdate_RequestValue(ParamId_t id, int32_t value)
 113:Core/Src/freertos.c **** {
 114:Core/Src/freertos.c ****   if (gParamUpdateQueueHandle == NULL)
 115:Core/Src/freertos.c ****   {
 116:Core/Src/freertos.c ****     return false;
 117:Core/Src/freertos.c ****   }
 118:Core/Src/freertos.c **** 
 119:Core/Src/freertos.c ****   ParamUpdateMsg_t txMsg;
 120:Core/Src/freertos.c ****   txMsg.id = id;
 121:Core/Src/freertos.c ****   txMsg.value = value;
 122:Core/Src/freertos.c **** 
 123:Core/Src/freertos.c ****   return (osMessageQueuePut(gParamUpdateQueueHandle, &txMsg, 0U, 0U) == osOK);
 124:Core/Src/freertos.c **** }
 125:Core/Src/freertos.c **** 
 126:Core/Src/freertos.c **** bool APP_ParamUpdate_Request(ParamId_t id)
 127:Core/Src/freertos.c **** {
 128:Core/Src/freertos.c ****   int32_t value = 0;
 129:Core/Src/freertos.c ****   if (!APP_ParamDict_GetValue(id, &value))
 130:Core/Src/freertos.c ****   {
 131:Core/Src/freertos.c ****     return false;
 132:Core/Src/freertos.c ****   }
 133:Core/Src/freertos.c **** 
 134:Core/Src/freertos.c ****   return APP_ParamUpdate_RequestValue(id, value);
 135:Core/Src/freertos.c **** }
