 251:Core/Src/freertos.c **** /* USER CODE END Header_StartTask03 */
 252:Core/Src/freertos.c **** void StartTask03(void *argument)
 253:Core/Src/freertos.c **** {
 254:Core/Src/freertos.c ****   /* USER CODE BEGIN StartTask03 */
 255:Core/Src/freertos.c ****   /* Infinite loop */
 256:Core/Src/freertos.c ****   for(;;)
