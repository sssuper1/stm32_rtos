 106:Core/Src/freertos.c **** /* Simple helpers for locking/unlocking parameter dictionary */
 107:Core/Src/freertos.c **** static inline void ParamDict_Lock(void)
 108:Core/Src/freertos.c **** {
 109:Core/Src/freertos.c ****   (void)osMutexAcquire(gParamMutexHandle, osWaitForever);
 110:Core/Src/freertos.c **** }
 111:Core/Src/freertos.c **** 
 112:Core/Src/freertos.c **** static inline void ParamDict_Unlock(void)
 113:Core/Src/freertos.c **** {
 114:Core/Src/freertos.c ****   (void)osMutexRelease(gParamMutexHandle);
 115:Core/Src/freertos.c **** }
 116:Core/Src/freertos.c **** 
 117:Core/Src/freertos.c **** bool APP_ParamUpdate_RequestValue(ParamId_t id, int32_t value)
 118:Core/Src/freertos.c **** {
 119:Core/Src/freertos.c ****   ParamUpdateMsg_t txMsg;
 120:Core/Src/freertos.c ****   txMsg.id = id;
 121:Core/Src/freertos.c ****   txMsg.value = value;
 122:Core/Src/freertos.c **** 
 123:Core/Src/freertos.c ****   ParamDict_Lock();
 124:Core/Src/freertos.c ****   (void)APP_ParamDict_SetValueUnsafe(PARAM_ID_UART_ACK_STATE, 3); /* pending */
 125:Core/Src/freertos.c ****   (void)APP_ParamDict_SetValueUnsafe(PARAM_ID_UART_ACK_CMD, 0xA1); /* request entered */
 126:Core/Src/freertos.c ****   ParamDict_Unlock();
 127:Core/Src/freertos.c **** 
 128:Core/Src/freertos.c ****   /* 优先同步直发：确保按 OK 后立刻尝试组帧并发送。 */
 129:Core/Src/freertos.c ****   if (UART_SendParamWrite(&txMsg))
 130:Core/Src/freertos.c ****   {
 131:Core/Src/freertos.c ****     return true;
 132:Core/Src/freertos.c ****   }
 133:Core/Src/freertos.c **** 
 134:Core/Src/freertos.c ****   /* 直发失败时再尝试入队，交给 UART 线程重试。 */
 135:Core/Src/freertos.c ****   if (gParamUpdateQueueHandle != NULL)
 136:Core/Src/freertos.c ****   {
 137:Core/Src/freertos.c ****     if (osMessageQueuePut(gParamUpdateQueueHandle, &txMsg, 0U, 0U) == osOK)
 138:Core/Src/freertos.c ****     {
 139:Core/Src/freertos.c ****       ParamDict_Lock();
 140:Core/Src/freertos.c ****       (void)APP_ParamDict_SetValueUnsafe(PARAM_ID_UART_ACK_CMD, 0xA2); /* queued */
 141:Core/Src/freertos.c ****       ParamDict_Unlock();
 142:Core/Src/freertos.c ****       return true;
 143:Core/Src/freertos.c ****     }
 144:Core/Src/freertos.c **** 
 145:Core/Src/freertos.c ****     ParamDict_Lock();
 146:Core/Src/freertos.c ****     (void)APP_ParamDict_SetValueUnsafe(PARAM_ID_UART_ACK_CMD, 0xA3); /* queue put failed */
ARM GAS  /tmp/cc86SiJF.s 			page 4


 147:Core/Src/freertos.c ****     ParamDict_Unlock();
 148:Core/Src/freertos.c ****   }
 149:Core/Src/freertos.c ****   else
 150:Core/Src/freertos.c ****   {
 151:Core/Src/freertos.c ****     ParamDict_Lock();
 152:Core/Src/freertos.c ****     (void)APP_ParamDict_SetValueUnsafe(PARAM_ID_UART_ACK_CMD, 0xA4); /* queue null */
 153:Core/Src/freertos.c ****     ParamDict_Unlock();
 154:Core/Src/freertos.c ****   }
 155:Core/Src/freertos.c **** 
 156:Core/Src/freertos.c ****   return false;
 157:Core/Src/freertos.c **** }
 158:Core/Src/freertos.c **** 
 159:Core/Src/freertos.c **** bool APP_ParamUpdate_Request(ParamId_t id)
 160:Core/Src/freertos.c **** {
 161:Core/Src/freertos.c ****   int32_t value = 0;
 162:Core/Src/freertos.c ****   if (!APP_ParamDict_GetValue(id, &value))
 163:Core/Src/freertos.c ****   {
 164:Core/Src/freertos.c ****     return false;
 165:Core/Src/freertos.c ****   }
 166:Core/Src/freertos.c **** 
 167:Core/Src/freertos.c ****   return APP_ParamUpdate_RequestValue(id, value);
 168:Core/Src/freertos.c **** }
