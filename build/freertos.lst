 205:Core/Src/freertos.c **** void StartDefaultTask(void *argument)
 206:Core/Src/freertos.c **** {
 207:Core/Src/freertos.c ****   /* USER CODE BEGIN StartDefaultTask */
 208:Core/Src/freertos.c ****   /* Initialize BSP (LED / LCD / Keys / UART helpers) and menu state machine */
 209:Core/Src/freertos.c ****   BSP_Init();
 210:Core/Src/freertos.c ****   BSP_Lcd_Init();
 211:Core/Src/freertos.c ****   BSP_Keys_Init();
 212:Core/Src/freertos.c **** 
 213:Core/Src/freertos.c ****   (void)APP_Menu_Init();
 214:Core/Src/freertos.c ****   uint32_t ignoreKeysUntil = osKernelGetTickCount() + 300U;
 215:Core/Src/freertos.c **** 
 216:Core/Src/freertos.c ****   /* Infinite loop */
 217:Core/Src/freertos.c ****   for(;;)
 218:Core/Src/freertos.c ****   {
 219:Core/Src/freertos.c ****     /* 1. Read key input (polling or from buffer) */
 220:Core/Src/freertos.c ****     MenuKey_t key = HMI_ReadKey();
 221:Core/Src/freertos.c ****     if (osKernelGetTickCount() < ignoreKeysUntil)
 222:Core/Src/freertos.c ****     {
 223:Core/Src/freertos.c ****       key = MENU_KEY_NONE;
 224:Core/Src/freertos.c ****     }
 225:Core/Src/freertos.c **** 
 226:Core/Src/freertos.c ****     /* 2. Drive menu state machine if there is a key event */
 227:Core/Src/freertos.c ****     if (key != MENU_KEY_NONE)
 228:Core/Src/freertos.c ****     {
 229:Core/Src/freertos.c ****       (void)APP_Menu_HandleKey(key);
 230:Core/Src/freertos.c ****     }
 231:Core/Src/freertos.c **** 
 232:Core/Src/freertos.c ****     /* 3. Delay to control polling period (e.g. 10ms) */
 233:Core/Src/freertos.c ****     osDelay(10);
 234:Core/Src/freertos.c ****   }
 235:Core/Src/freertos.c ****   /* USER CODE END StartDefaultTask */
 236:Core/Src/freertos.c **** }
 237:Core/Src/freertos.c **** 
 238:Core/Src/freertos.c **** /* USER CODE BEGIN Header_StartTask02 */
 239:Core/Src/freertos.c **** /**
 240:Core/Src/freertos.c **** * @brief Function implementing the UART_Task thread.
 241:Core/Src/freertos.c **** * @param argument: Not used
 242:Core/Src/freertos.c **** * @retval None
 243:Core/Src/freertos.c **** */
 244:Core/Src/freertos.c **** /* USER CODE END Header_StartTask02 */
 245:Core/Src/freertos.c **** void StartTask02(void *argument)
 246:Core/Src/freertos.c **** {
 247:Core/Src/freertos.c ****   /* USER CODE BEGIN StartTask02 */
 248:Core/Src/freertos.c ****   /* UART_Comm_Task: wait for parameter update messages and send via UART (skeleton) */
 249:Core/Src/freertos.c ****   ParamUpdateMsg_t msg;
 250:Core/Src/freertos.c **** 
 251:Core/Src/freertos.c ****   /* Infinite loop */
 252:Core/Src/freertos.c ****   for(;;)
 253:Core/Src/freertos.c ****   {
 254:Core/Src/freertos.c ****     /* Block until there is a new parameter update request from HMI */
 255:Core/Src/freertos.c ****     if (osMessageQueueGet(gParamUpdateQueueHandle, &msg, NULL, osWaitForever) == osOK)
 256:Core/Src/freertos.c ****     {
 257:Core/Src/freertos.c ****       /* Assemble UART frame and transmit according to protocol. */
 258:Core/Src/freertos.c ****       UART_SendParamWrite(&msg);
 259:Core/Src/freertos.c ****     }
 260:Core/Src/freertos.c ****   }
 261:Core/Src/freertos.c ****   /* USER CODE END StartTask02 */
ARM GAS  /tmp/ccnHAnLF.s 			page 6


 262:Core/Src/freertos.c **** }
