 315:Core/Src/app_menu.c ****   }
 316:Core/Src/app_menu.c **** 
 317:Core/Src/app_menu.c ****   /* 先讓當前節點有機會“攔截”按鍵（例如在參數編輯模式） */
 318:Core/Src/app_menu.c ****   if ((s_current != 0) && (s_current->key_cb != 0))
 319:Core/Src/app_menu.c ****   {
 320:Core/Src/app_menu.c ****     int handled = s_current->key_cb(key);
 321:Core/Src/app_menu.c ****     if (handled != 0)
 322:Core/Src/app_menu.c ****     {
 323:Core/Src/app_menu.c ****       if (s_current->render_cb != 0)
 324:Core/Src/app_menu.c ****       {
 325:Core/Src/app_menu.c ****         s_current->render_cb(s_current);
 326:Core/Src/app_menu.c ****       }
 327:Core/Src/app_menu.c ****       return s_current;
 328:Core/Src/app_menu.c ****     }
 329:Core/Src/app_menu.c ****   }
