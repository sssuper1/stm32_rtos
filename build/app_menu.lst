 361:Core/Src/app_menu.c **** /* 工作模式编辑逻辑示例：
 362:Core/Src/app_menu.c ****  * - 在“操作模式设置”菜单下，UP/DOWN 在 0~3 范围内切换
 363:Core/Src/app_menu.c ****  * - OK / BACK 不拦截，交给默认导航
 364:Core/Src/app_menu.c ****  */
 365:Core/Src/app_menu.c **** static int MenuKeyHandler_WorkMode(MenuKey_t key)
 366:Core/Src/app_menu.c **** {
 367:Core/Src/app_menu.c ****   int32_t current = 0;
 368:Core/Src/app_menu.c ****   if (!APP_ParamDict_GetValue(PARAM_ID_WORK_MODE, &current))
 369:Core/Src/app_menu.c ****   {
 370:Core/Src/app_menu.c ****     return 0;
 371:Core/Src/app_menu.c ****   }
 372:Core/Src/app_menu.c **** 
 373:Core/Src/app_menu.c ****   if (key == MENU_KEY_UP)
 374:Core/Src/app_menu.c ****   {
 375:Core/Src/app_menu.c ****     if (current > 0)
 376:Core/Src/app_menu.c ****     {
 377:Core/Src/app_menu.c ****       (void)APP_ParamDict_TrySetValue(PARAM_ID_WORK_MODE, current - 1);
 378:Core/Src/app_menu.c ****     }
 379:Core/Src/app_menu.c ****     return 1;
 380:Core/Src/app_menu.c ****   }
 381:Core/Src/app_menu.c **** 
 382:Core/Src/app_menu.c ****   if (key == MENU_KEY_DOWN)
 383:Core/Src/app_menu.c ****   {
 384:Core/Src/app_menu.c ****     if (current < 3)
 385:Core/Src/app_menu.c ****     {
 386:Core/Src/app_menu.c ****       (void)APP_ParamDict_TrySetValue(PARAM_ID_WORK_MODE, current + 1);
 387:Core/Src/app_menu.c ****     }
 388:Core/Src/app_menu.c ****     return 1;
 389:Core/Src/app_menu.c ****   }
 390:Core/Src/app_menu.c **** 
 391:Core/Src/app_menu.c ****   return 0;
 392:Core/Src/app_menu.c **** }
 393:Core/Src/app_menu.c **** 
