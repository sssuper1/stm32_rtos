  68:Core/Src/app_menu.c **** static void Menu_FormatMilli(char *out, size_t outSize, int32_t value)
  69:Core/Src/app_menu.c **** {
  70:Core/Src/app_menu.c ****   long integerPart = (long)(value / 1000);
  71:Core/Src/app_menu.c ****   long fracPart = (long)(value % 1000);
  72:Core/Src/app_menu.c **** 
  73:Core/Src/app_menu.c ****   if (fracPart < 0)
  74:Core/Src/app_menu.c ****   {
  75:Core/Src/app_menu.c ****     fracPart = -fracPart;
  76:Core/Src/app_menu.c ****   }
  77:Core/Src/app_menu.c **** 
  78:Core/Src/app_menu.c ****   (void)snprintf(out, outSize, "%ld.%03ld", integerPart, fracPart);
  79:Core/Src/app_menu.c **** }
  80:Core/Src/app_menu.c **** 
  81:Core/Src/app_menu.c **** static void Menu_RenderBlankRows(uint8_t startRow, uint8_t endRow)
  82:Core/Src/app_menu.c **** {
  83:Core/Src/app_menu.c ****   for (uint8_t row = startRow; row <= endRow; ++row)
  84:Core/Src/app_menu.c ****   {
  85:Core/Src/app_menu.c ****     BSP_Lcd_PrintLine(row, "");
  86:Core/Src/app_menu.c ****   }
  87:Core/Src/app_menu.c **** }
  88:Core/Src/app_menu.c **** 
  89:Core/Src/app_menu.c **** static void Menu_RenderParamValue(ParamId_t id, int32_t value, char *out, size_t outSize)
  90:Core/Src/app_menu.c **** {
  91:Core/Src/app_menu.c ****   if ((out == NULL) || (outSize == 0u))
  92:Core/Src/app_menu.c ****   {
  93:Core/Src/app_menu.c ****     return;
  94:Core/Src/app_menu.c ****   }
  95:Core/Src/app_menu.c **** 
  96:Core/Src/app_menu.c ****   if ((id == PARAM_ID_FIXED_FREQ) ||
  97:Core/Src/app_menu.c ****       (id == PARAM_ID_ADAPT_FREQ1) ||
  98:Core/Src/app_menu.c ****       (id == PARAM_ID_ADAPT_FREQ2) ||
ARM GAS  /tmp/ccJMlkfl.s 			page 5


  99:Core/Src/app_menu.c ****       (id == PARAM_ID_ADAPT_FREQ3) ||
 100:Core/Src/app_menu.c ****       (id == PARAM_ID_ADAPT_FREQ4))
 101:Core/Src/app_menu.c ****   {
 102:Core/Src/app_menu.c ****     Menu_FormatMilli(out, outSize, value);
 103:Core/Src/app_menu.c ****     return;
 104:Core/Src/app_menu.c ****   }
 105:Core/Src/app_menu.c **** 
 106:Core/Src/app_menu.c ****   (void)snprintf(out, outSize, "%ld", (long)value);
 107:Core/Src/app_menu.c **** }
