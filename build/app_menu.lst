 510:Core/Src/app_menu.c **** /* 工作模式编辑逻辑示例：
 511:Core/Src/app_menu.c ****  * - 在“操作模式设置”菜单下，UP/DOWN 在 0~3 范围内切换
 512:Core/Src/app_menu.c ****  * - OK / BACK 不拦截，交给默认导航
ARM GAS  /tmp/ccJMlkfl.s 			page 16


 513:Core/Src/app_menu.c ****  */
 514:Core/Src/app_menu.c **** static int MenuKeyHandler_WorkMode(MenuKey_t key)
 515:Core/Src/app_menu.c **** {
 516:Core/Src/app_menu.c ****   int32_t current = 0;
 517:Core/Src/app_menu.c ****   if (!APP_ParamDict_GetValue(PARAM_ID_WORK_MODE, &current))
 518:Core/Src/app_menu.c ****   {
 519:Core/Src/app_menu.c ****     return 0;
 520:Core/Src/app_menu.c ****   }
 521:Core/Src/app_menu.c **** 
 522:Core/Src/app_menu.c ****   if (key == MENU_KEY_UP)
 523:Core/Src/app_menu.c ****   {
 524:Core/Src/app_menu.c ****     if (current > 0)
 525:Core/Src/app_menu.c ****     {
 526:Core/Src/app_menu.c ****       int32_t next = current - 1;
 527:Core/Src/app_menu.c ****       if (APP_ParamDict_TrySetValue(PARAM_ID_WORK_MODE, next))
 528:Core/Src/app_menu.c ****       {
 529:Core/Src/app_menu.c ****         (void)APP_ParamUpdate_Request(PARAM_ID_WORK_MODE);
 530:Core/Src/app_menu.c ****       }
 531:Core/Src/app_menu.c ****     }
 532:Core/Src/app_menu.c ****     return 1;
 533:Core/Src/app_menu.c ****   }
 534:Core/Src/app_menu.c **** 
 535:Core/Src/app_menu.c ****   if (key == MENU_KEY_DOWN)
 536:Core/Src/app_menu.c ****   {
 537:Core/Src/app_menu.c ****     if (current < 3)
 538:Core/Src/app_menu.c ****     {
 539:Core/Src/app_menu.c ****       int32_t next = current + 1;
 540:Core/Src/app_menu.c ****       if (APP_ParamDict_TrySetValue(PARAM_ID_WORK_MODE, next))
 541:Core/Src/app_menu.c ****       {
 542:Core/Src/app_menu.c ****         (void)APP_ParamUpdate_Request(PARAM_ID_WORK_MODE);
 543:Core/Src/app_menu.c ****       }
 544:Core/Src/app_menu.c ****     }
 545:Core/Src/app_menu.c ****     return 1;
 546:Core/Src/app_menu.c ****   }
 547:Core/Src/app_menu.c **** 
 548:Core/Src/app_menu.c ****   return 0;
 549:Core/Src/app_menu.c **** }
