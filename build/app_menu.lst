 307:Core/Src/app_menu.c **** 
 308:Core/Src/app_menu.c **** static void Menu_PrintHeaderPath(const MenuNode_t *node)
 309:Core/Src/app_menu.c **** {
 310:Core/Src/app_menu.c ****   char buf[32];
 311:Core/Src/app_menu.c ****   const MenuNode_t *stack[8];
 312:Core/Src/app_menu.c ****   uint8_t depth = 0u;
 313:Core/Src/app_menu.c **** 
 314:Core/Src/app_menu.c ****   while ((node != 0) && (depth < (uint8_t)(sizeof(stack) / sizeof(stack[0]))))
 315:Core/Src/app_menu.c ****   {
 316:Core/Src/app_menu.c ****     stack[depth++] = node;
 317:Core/Src/app_menu.c ****     node = node->parent;
 318:Core/Src/app_menu.c ****   }
 319:Core/Src/app_menu.c **** 
 320:Core/Src/app_menu.c ****   buf[0] = '\0';
 321:Core/Src/app_menu.c ****   for (int i = (int)depth - 1; i >= 0; --i)
 322:Core/Src/app_menu.c ****   {
 323:Core/Src/app_menu.c ****     const char *seg = (stack[i]->title != 0) ? stack[i]->title : "?";
 324:Core/Src/app_menu.c ****     size_t used = strlen(buf);
 325:Core/Src/app_menu.c ****     size_t remain = sizeof(buf) - used - 1u;
 326:Core/Src/app_menu.c **** 
 327:Core/Src/app_menu.c ****     if ((used > 0u) && (remain > 0u))
 328:Core/Src/app_menu.c ****     {
 329:Core/Src/app_menu.c ****       strncat(buf, "/", remain);
 330:Core/Src/app_menu.c ****       used = strlen(buf);
 331:Core/Src/app_menu.c ****       remain = sizeof(buf) - used - 1u;
 332:Core/Src/app_menu.c ****     }
 333:Core/Src/app_menu.c **** 
 334:Core/Src/app_menu.c ****     if (remain > 0u)
 335:Core/Src/app_menu.c ****     {
 336:Core/Src/app_menu.c ****       strncat(buf, seg, remain);
 337:Core/Src/app_menu.c ****     }
 338:Core/Src/app_menu.c ****   }
 339:Core/Src/app_menu.c **** 
 340:Core/Src/app_menu.c ****   if (buf[0] == '\0')
 341:Core/Src/app_menu.c ****   {
 342:Core/Src/app_menu.c ****     (void)snprintf(buf, sizeof(buf), "MAIN");
 343:Core/Src/app_menu.c ****   }
 344:Core/Src/app_menu.c **** 
 345:Core/Src/app_menu.c ****   BSP_Lcd_PrintLine(0, buf);
 346:Core/Src/app_menu.c **** }
